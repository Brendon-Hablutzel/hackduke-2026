# App
SECRET_KEY=change-me-to-a-long-random-string
APP_BASE_URL=http://localhost:8000
LOG_LEVEL=INFO

# Gmail / Indexing
MAX_EMAILS=500
CREDENTIALS_PATH=/app/credentials/credentials.json

# Embeddings
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ChromaDB
CHROMA_HOST=chromadb
CHROMA_PORT=8000
CHROMA_COLLECTION_PREFIX=emails

# Storage
DATA_DIR=/app/data

# Gemini (for email parsing)
GEMINI_API_KEY=your-gemini-api-key-here

# PostgreSQL (todo cache)
DATABASE_URL=postgresql://emailsearch:emailsearch@localhost:5432/emailsearch
